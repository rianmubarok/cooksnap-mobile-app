# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Dart source files
*.dart text eol=lf

# YAML files
*.yaml text eol=lf
*.yml  text eol=lf

# JSON files
*.json text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
