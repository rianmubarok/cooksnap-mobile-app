[
  {
    "id": "_pb_users_auth_",
    "name": "users",
    "type": "auth",
    "system": false,
    "schema": [
      {
        "id": "users_name",
        "name": "name",
        "type": "text",
        "system": false,
        "required": false,
        "presentable": true,
        "options": {
          "min": null,
          "max": 100,
          "pattern": ""
        }
      },
      {
        "id": "users_profile_image",
        "name": "profile_image",
        "type": "file",
        "system": false,
        "required": false,
        "presentable": false,
        "options": {
          "mimeTypes": ["image/jpeg", "image/png", "image/webp"],
          "thumbs": ["100x100"],
          "maxSelect": 1,
          "maxSize": 5242880,
          "protected": false
        }
      }
    ],
    "listRule": "id = @request.auth.id",
    "viewRule": "id = @request.auth.id",
    "createRule": "",
    "updateRule": "id = @request.auth.id",
    "deleteRule": "id = @request.auth.id",
    "options": {
      "allowEmailAuth": true,
      "allowOAuth2Auth": false,
      "allowUsernameAuth": false,
      "exceptEmailDomains": null,
      "manageRule": null,
      "minPasswordLength": 6,
      "onlyEmailDomains": null,
      "onlyVerified": false,
      "requireEmail": true
    }
  },
