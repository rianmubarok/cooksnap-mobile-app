    "type": "base",
    "system": false,
    "schema": [
      {
        "id": "favorites_user_id",
        "name": "user_id",
        "type": "relation",
        "system": false,
        "required": true,
        "presentable": false,
        "options": {
          "collectionId": "_pb_users_auth_",
          "cascadeDelete": true,
          "minSelect": null,
          "maxSelect": 1,
          "displayFields": ["name", "email"]
